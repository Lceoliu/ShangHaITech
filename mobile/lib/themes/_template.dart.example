// themes/_template.dart.example — 复制为 themes/<your_id>.dart
//
// 使用说明：
//   1. 把文件复制为 lib/themes/<your_id>.dart
//   2. 全局替换 'my_theme' / 'MyTheme' / 'YourGitHubHandle' 等占位符
//   3. 填写颜色常量和 BetterTokens
//   4. 在 lib/theming/registry.dart 的 ThemeRegistry.all 按字母序追加 MyTheme
//   5. 运行 flutter test test/theming/theme_files_test.dart 确认通过
//
// 规则提醒（详见 README.md）：
//   ✅ 可以写：颜色常量、ColorScheme、BetterTokens、SubjectAccentScheme、VariantSet、ThemeData 字段
//   ❌ 不可以：import features/shared/core、定义 Widget、引入新 enum case、调用 API

import 'package:flutter/material.dart';

import '../theming/better_theme.dart';
import '../theming/chrome/chrome_bundle.dart';
import '../theming/home/home_slot_bundle.dart';
import '../theming/tokens/better_tokens.dart';
import '../theming/tokens/subject_accents.dart';
import '../theming/tokens/variant_bundle.dart';

// ── 颜色常量（file-private，外部不可见）──────────────────────────────────────

const _primary = Color(0xFF000000); // 替换为你的主色
const _surface = Color(0xFFFFFFFF); // 背景色
const _onSurface = Color(0xFF1A1A1A); // 文字色

// 补充更多颜色常量...

// ── ThemeData 构建函数 ───────────────────────────────────────────────────────

ThemeData _buildThemeData() {
  const colorScheme = ColorScheme(
    brightness: Brightness.light, // 或 Brightness.dark
    primary: _primary,
    onPrimary: Color(0xFFFFFFFF),
    primaryContainer: Color(0xFF000000), // 替换
    onPrimaryContainer: Color(0xFFFFFFFF), // 替换
    secondary: Color(0xFF000000), // 替换
    onSecondary: Color(0xFFFFFFFF),
    secondaryContainer: Color(0xFF000000), // 替换
    onSecondaryContainer: Color(0xFFFFFFFF), // 替换
    tertiary: Color(0xFF000000), // 替换
    onTertiary: Color(0xFFFFFFFF),
    tertiaryContainer: Color(0xFF000000), // 替换
    onTertiaryContainer: Color(0xFFFFFFFF), // 替换
    error: Color(0xFFB00020),
    onError: Color(0xFFFFFFFF),
    errorContainer: Color(0xFFFFDAD6),
    onErrorContainer: Color(0xFF410002),
    surface: _surface,
    onSurface: _onSurface,
    surfaceContainerLowest: Color(0xFFFFFFFF), // 替换
    surfaceContainerLow: Color(0xFFF5F5F5), // 替换
    surfaceContainer: Color(0xFFEEEEEE), // 替换
    surfaceContainerHigh: Color(0xFFE8E8E8), // 替换
    surfaceContainerHighest: Color(0xFFE0E0E0), // 替换
    onSurfaceVariant: Color(0xFF666666), // 替换
    outline: Color(0xFF888888), // 替换
    outlineVariant: Color(0xFFCCCCCC), // 替换
    inverseSurface: Color(0xFF1A1A1A),
    onInverseSurface: Color(0xFFEEEEEE),
    inversePrimary: Color(0xFF000000), // 替换
    shadow: Color(0xFF000000),
    scrim: Color(0xFF000000),
    surfaceTint: Colors.transparent,
  );

  return ThemeData(
    colorScheme: colorScheme,
    scaffoldBackgroundColor: colorScheme.surface,
    useMaterial3: true,
    extensions: const [
      BetterTokens(
        fontFamilies: FontFamilyTokens(sans: 'system', mono: 'monospace'),
        typeScale: TypeScale(
          displayLarge: TextStyle(fontSize: 56, fontWeight: FontWeight.w800, letterSpacing: -1.5),
          displayMedium: TextStyle(fontSize: 45, fontWeight: FontWeight.w800, letterSpacing: -1.0),
          displaySmall: TextStyle(fontSize: 36, fontWeight: FontWeight.w700, letterSpacing: -0.5),
          headlineLarge: TextStyle(fontSize: 32, fontWeight: FontWeight.w700, letterSpacing: -0.5),
          headlineMedium: TextStyle(fontSize: 28, fontWeight: FontWeight.w800, letterSpacing: -0.8),
          headlineSmall: TextStyle(fontSize: 24, fontWeight: FontWeight.w700, letterSpacing: -0.5),
          titleLarge: TextStyle(fontSize: 22, fontWeight: FontWeight.w700),
          titleMedium: TextStyle(fontSize: 17, fontWeight: FontWeight.w700, letterSpacing: -0.2),
          titleSmall: TextStyle(fontSize: 14, fontWeight: FontWeight.w600, letterSpacing: -0.1),
          bodyLarge: TextStyle(fontSize: 15, height: 1.5),
          bodyMedium: TextStyle(fontSize: 14, height: 1.45),
          bodySmall: TextStyle(fontSize: 12, height: 1.4),
          labelLarge: TextStyle(fontSize: 14, fontWeight: FontWeight.w700),
          labelMedium: TextStyle(fontSize: 12, fontWeight: FontWeight.w600, letterSpacing: 0.5),
          labelSmall: TextStyle(fontSize: 11, fontWeight: FontWeight.w500, letterSpacing: 0.5),
        ),
        radii: BorderRadiusTokens(none: 0, xs: 8, sm: 16, md: 24, lg: 32, pill: 999),
        borders: BorderWidthTokens(hairline: 0.5, thin: 1, regular: 2),
        spacing: SpacingTokens(),
        motion: MotionTokens(),
        shadows: ShadowTokens(
          none: [],
          subtle: [BoxShadow(color: Color(0x0F000000), blurRadius: 12, offset: Offset(0, 4))],
          elevated: [BoxShadow(color: Color(0x0F000000), blurRadius: 24, offset: Offset(0, 8))],
          dramatic: [BoxShadow(color: Color(0x0F000000), blurRadius: 48, offset: Offset(0, 16))],
        ),
        decorations: null,
      ),
      SubjectAccentScheme(
        computer: SubjectAccent(bg: Color(0xFFE6F2FF), text: Color(0xFF0D3A6B), accent: Color(0xFF2B6CB0)),
        bio: SubjectAccent(bg: Color(0xFFE8F8EE), text: Color(0xFF1A4A2E), accent: Color(0xFF2D6A4F)),
        design: SubjectAccent(bg: Color(0xFFFFEBE3), text: Color(0xFF4A1E00), accent: Color(0xFF9A3412)),
        chemistry: SubjectAccent(bg: Color(0xFFF3E8FF), text: Color(0xFF3B1A6B), accent: Color(0xFF6B21A8)),
        physics: SubjectAccent(bg: Color(0xFFEEF2FF), text: Color(0xFF1E3A8A), accent: Color(0xFF3730A3)),
        math: SubjectAccent(bg: Color(0xFFFFF4CC), text: Color(0xFF4A3500), accent: Color(0xFF92651A)),
        economics: SubjectAccent(bg: Color(0xFFFFF0F3), text: Color(0xFF4A0020), accent: Color(0xFF9D174D)),
        engineering: SubjectAccent(bg: Color(0xFFFFF7ED), text: Color(0xFF431407), accent: Color(0xFFEA580C)),
        fallback: SubjectAccent(bg: Color(0xFFF5F5F5), text: Color(0xFF1A1A1A), accent: Color(0xFF000000)),
      ),
      VariantBundleExtension(VariantSet(
        card: CardVariant.material,
        button: ButtonVariant.material,
        chip: ChipVariant.stadium,
        input: InputVariant.filled,
        divider: DividerVariant.hairline,
        appBar: AppBarVariant.transparent,
        nav: NavVariant.material,
      )),
    ],
    // textTheme, cardTheme, inputDecorationTheme, chipTheme, appBarTheme...
    pageTransitionsTheme: const PageTransitionsTheme(
      builders: {
        TargetPlatform.android: CupertinoPageTransitionsBuilder(),
        TargetPlatform.iOS: CupertinoPageTransitionsBuilder(),
        TargetPlatform.windows: CupertinoPageTransitionsBuilder(),
        TargetPlatform.linux: CupertinoPageTransitionsBuilder(),
        TargetPlatform.macOS: CupertinoPageTransitionsBuilder(),
      },
    ),
  );
}

// ── 主题常量（公开，注册表引用此常量）──────────────────────────────────────────

const MyTheme = BetterTheme(
  id: 'my_theme', // 与文件名一致（不含 .dart）
  name: '我的主题',
  authorName: 'YourGitHubHandle',
  description: '一句话描述这个主题的视觉概念。',
  brightness: Brightness.light, // 或 Brightness.dark
  buildThemeData: _buildThemeData,
  variants: VariantSet(),
  homeStyle: HomeStyleId.sunlitV1,
  chromeStyle: ChromeStyleId.sunlitV1,
  preview: ThemePreview(
    swatch: [
      Color(0xFF000000), // 主色
      Color(0xFF333333), // 次色
      Color(0xFFFFFFFF), // 背景
      Color(0xFFEEEEEE), // 卡片背景
      Color(0xFF1A1A1A), // 文字色
    ],
  ),
);
